# ============================================================
# AI Resume & Career Advisor — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=5000
NODE_ENV=development
# NODE_ENV=production   ← set this when deploying

# ------------------------------------------------------------
# MongoDB
# LOCAL (development):
# MONGO_URI=mongodb://localhost:27017/ai-resume-advisor
#
# ATLAS (production/deployment) — replace with your cluster URI:
# 1. Go to https://cloud.mongodb.com
# 2. Click your cluster → Connect → Drivers
# 3. Copy the connection string and replace <username>, <password>, <cluster>
MONGO_URI=mongodb+srv://kumarshiv080908_db_user:L8pt2uACL6ZPcvnN@resumechecker.vilf6es.mongodb.net/?appName=ResumeChecker
# ------------------------------------------------------------

# ------------------------------------------------------------
# JWT Authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET=your_random_64_char_secret_here_change_this
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------
# Groq API Key (https://console.groq.com)
# ------------------------------------------------------------
GROQ_API_KEY=gsk_your_groq_api_key_here

# ------------------------------------------------------------
# CORS — Frontend URL
# LOCAL:      http://localhost:3000
# PRODUCTION: https://your-frontend-domain.vercel.app
# ------------------------------------------------------------
CLIENT_URL=http://localhost:3000

# ------------------------------------------------------------
# Python AI Microservice URL
# LOCAL:      http://localhost:8000
# PRODUCTION: https://your-ai-service.railway.app
# ------------------------------------------------------------
# AI_SERVICE_URL=http://localhost:8000
