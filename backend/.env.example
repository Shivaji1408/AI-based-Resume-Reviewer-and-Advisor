# ============================================================
# AI Resume & Career Advisor — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB — use Atlas connection string for production
MONGO_URI=mongodb://localhost:27017/ai-resume-advisor
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/ai-resume-advisor

# JWT Authentication
JWT_SECRET=your_random_32_char_secret_here_change_this
JWT_EXPIRES_IN=7d

# Groq API Key (Get free key at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Optional: Python AI Service URL (future integration)
# AI_SERVICE_URL=http://localhost:8000
